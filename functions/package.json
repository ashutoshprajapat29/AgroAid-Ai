    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "firebase-admin": "^12.2.0",
    "firebase-functions": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "typescript": "^5.4.5"
  },
  "private": true
}
